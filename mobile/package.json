{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:device": "set EXPO_NO_DEPENDENCY_VALIDATION=1&& adb reverse tcp:3000 tcp:3000 && expo start --lan",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web --port 19006",
    "export:web": "expo export --platform web --output-dir dist"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "expo": "~54.0.34",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-file-system": "~19.0.22",
    "expo-image-picker": "~17.0.11",
    "expo-print": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-draggable-grid": "^2.2.2",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
